# ── Discord ──────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
COMMAND_PREFIX=/                          # Command prefix (default: /)
ALLOWED_CHANNEL_IDS=[123456789012345678]  # Allowed channel IDs (JSON array)
ALLOWED_USER_IDS=[123456789012345678]     # Allowed user IDs (JSON array)
DISCORD_MESSAGE_LIMIT=2000               # Discord message character limit

# ── Agent ────────────────────────────────────────────────────
# Supported types: claude | gemini | codex | aider | custom
AGENT_TYPE=claude

# CLI executable path (auto-detected from preset if empty)
#   claude → claude
#   gemini → gemini
#   codex  → codex
#   aider  → aider
AGENT_BINARY=/opt/homebrew/bin/claude

# Custom args template (only for AGENT_TYPE=custom)
# Comma-separated, use {prompt} as placeholder
# Example: --message,{prompt},--yes
AGENT_ARGS=

# Working directory for the agent
AGENT_WORKING_DIR=/path/to/your/workspace

# Task timeout (seconds) — 2 hours
AGENT_TIMEOUT=7200

# Max output characters for Discord
AGENT_MAX_OUTPUT=3000

# Max concurrent sessions
AGENT_MAX_CONCURRENT=3

# How long to keep completed sessions for follow-up replies (seconds, default 30 min)
SESSION_TTL_SECONDS=1800

# ── Permission ───────────────────────────────────────────────
# Permission handling mode:
#   auto_approve — Skip all permission prompts (default, uses --dangerously-skip-permissions etc.)
#   relay        — Relay permission prompts to Discord as Approve/Deny buttons
#   deny         — Auto-deny all permission prompts
AGENT_PERMISSION_MODE=auto_approve

# Seconds to wait for user response before auto-denying (relay mode only)
AGENT_PERMISSION_TIMEOUT=300

# Seconds of no output before checking for permission prompt (relay mode only)
AGENT_STALL_TIMEOUT=5.0

# ── Polling ──────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=1.0                 # Task completion polling interval (seconds)

# ── Notifications ────────────────────────────────────────────
NOTIFY_ON_COMPLETE=true
NOTIFY_ON_ERROR=true

# ── Restart ──────────────────────────────────────────────────
SKIP_MISSED_MESSAGES=true                 # Skip queued messages on restart (true/false)

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO                            # DEBUG | INFO | WARNING | ERROR

# ──────────────────────────────────────────────────────────────
# Quick Setup Examples:
#
# Claude Code:
#   AGENT_TYPE=claude
#   AGENT_BINARY=claude
#
# Gemini CLI:
#   AGENT_TYPE=gemini
#   AGENT_BINARY=gemini
#
# OpenAI Codex CLI:
#   AGENT_TYPE=codex
#   AGENT_BINARY=codex
#
# Aider:
#   AGENT_TYPE=aider
#   AGENT_BINARY=aider
#
# Custom agent:
#   AGENT_TYPE=custom
#   AGENT_BINARY=/path/to/my-agent
#   AGENT_ARGS=--run,{prompt},--no-interactive
# ──────────────────────────────────────────────────────────────
